enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemType {
  CHEST
  COLOR_DROP
  COLOR
  BOOST
}

enum EffectType {
  COIN_X2_NEXT_SESSION
  COIN_X2_TIMED
}

model User {
  id         String   @id @default(uuid())
  coins      Int      @default(0)

  progressColor   String  @default("#646cff")
  textColor       String  @default("#333333")
  buttonColor     String  @default("#646cff")
  backgroundColor String  @default("#ffffff")
  darkThemeEnabled Boolean @default(false)

  createdAt  DateTime @default(now())
  effects    UserEffect[]
}


model Chest {
  id            String   @id @default(uuid())
  name          String
  description   String
  cost          Int
  rarity        Rarity
  type          ItemType @default(CHEST)
  isInInventory Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model ColorDrop {
  id            String   @id @default(uuid())
  name          String
  description   String
  cost          Int
  rarity        Rarity
  type          ItemType @default(COLOR_DROP)

  r             Int
  g             Int
  b             Int

  isInInventory Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Color {
  id            String   @id @default(uuid())
  name          String
  description   String
  cost          Int
  rarity        Rarity
  type          ItemType @default(COLOR)

  r             Int
  g             Int
  b             Int

  isInInventory Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model BoostItem {
  id            String   @id @default(uuid())
  name          String
  description   String
  cost          Int
  rarity        Rarity
  type          ItemType @default(BOOST)
  boostKind     EffectType
  isInInventory Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model UserEffect {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectType  EffectType
  multiplier  Float      @default(2)
  expiresAt   DateTime?
  chargesLeft Int?
  createdAt   DateTime   @default(now())
}



generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id              String           @id @default(uuid())
  name            String
  sessions        Session[]
  currentSessions CurrentSession[]   
  createdAt       DateTime         @default(now())
}

model Session {
  id          String    @id @default(uuid())
  categoryId  String?   // теперь может быть null
  category    Category? @relation(fields: [categoryId], references: [id])
  startTime   DateTime
  endTime     DateTime
  durationSec Int
  createdAt   DateTime  @default(now())
}

model CurrentSession {
  id         String   @id @default(uuid())
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  startTime  DateTime
  createdAt  DateTime @default(now())
}
